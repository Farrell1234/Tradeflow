# PostgreSQL connection string (Railway provides this automatically)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Server port (Railway sets this automatically)
PORT=3001

# Set to "production" on Railway
NODE_ENV=production

# The public URL of this backend service (used for webhook URLs shown to users)
BACKEND_URL=https://your-app.up.railway.app

# Frontend URL for CORS — in production this is the same as BACKEND_URL
# In local dev: http://localhost:5173
FRONTEND_URL=https://your-app.up.railway.app

# JWT signing secret — generate with:
# node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change-me-to-a-long-random-string

# ── Tradovate ─────────────────────────────────────────────────────────
# Get CID + Secret from: tradovate.com → Account → API → create application
TRADOVATE_USERNAME=your@email.com
TRADOVATE_PASSWORD=yourpassword
TRADOVATE_CID=your-client-id
TRADOVATE_SECRET=your-client-secret
TRADOVATE_APP_ID=TradeFlow
TRADOVATE_MODE=demo

# ── Anthropic (optional — users can set their own key in Settings) ────
ANTHROPIC_API_KEY=sk-ant-...

# ── Stripe (configure later) ─────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID=price_...
